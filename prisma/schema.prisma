// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS & AUTH
// ============================================
model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  image           String?
  phone           String?
  role            Role      @default(USER)
  emailVerified   DateTime?
  stripeCustomerId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  agent           Agent?
  properties      Property[]
  favorites       Favorite[]
  wishlist        Wishlist[]
  searchAlerts    SearchAlert[]
  reviews         Review[]
  deals           Deal[]
  payments        Payment[]

  @@map("users")
}

enum Role {
  ADMIN
  AGENT
  USER
  OWNER
}

// ============================================
// AGENTS
// ============================================
model Agent {
  id                 String    @id @default(cuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone              String
  company            String
  officeAddress      String?
  officePhone        String?
  cnic               String?
  verified           Boolean   @default(false)
  stripeAccountId    String?
  rating             Float     @default(0)
  totalReviews       Int       @default(0)
  totalDealsCompleted Int     @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  properties         Property[]
  reviews            Review[]
  deals              Deal[]
  payments           Payment[]

  @@map("agents")
}

// ============================================
// PROPERTIES
// ============================================
model Property {
  id                String        @id @default(cuid())
  title             String
  description       String?
  price             Int
  priceFormatted    String?
  city              String
  area              String?
  propertyType      PropertyType  @default(HOUSE)
  beds              Int           @default(0)
  baths             Int           @default(0)
  areaSqft          Int?
  furnished         Boolean       @default(false)
  floor             Int?
  builtYear         Int?
  latitude          Float?
  longitude         Float?
  images            String[]
  videoUrl          String?
  videoPlatform     VideoPlatform?
  agentId           String?
  agent             Agent?        @relation(fields: [agentId], references: [id])
  ownerId           String?
  owner             User?         @relation(fields: [ownerId], references: [id])
  isPremium         Boolean       @default(false)
  premiumExpiresAt  DateTime?
  isFeatured        Boolean       @default(false)
  featuredExpiresAt DateTime?
  status            PropertyStatus @default(PENDING)
  views             Int           @default(0)
  whatsappClicks    Int           @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relations
  favorites         Favorite[]
  wishlist          Wishlist[]
  reviews           Review[]
  deals             Deal[]
  payments          Payment[]

  @@map("properties")
}

enum PropertyType {
  HOUSE
  FLAT
  PLOT
  COMMERCIAL
  FARMHOUSE
}

enum VideoPlatform {
  TIKTOK
  YOUTUBE
  DAILYMOTION
}

enum PropertyStatus {
  PENDING
  APPROVED
  REJECTED
  SOLD
}

// ============================================
// FAVORITES & WISHLIST
// ============================================
model Favorite {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
  @@map("favorites")
}

model Wishlist {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
  @@map("wishlist")
}

// ============================================
// REVIEWS
// ============================================
model Review {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  agentId    String
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating     Int      @default(5)
  comment    String?
  createdAt  DateTime @default(now())

  @@map("reviews")
}

// ============================================
// DEALS / ESCROW
// ============================================
model Deal {
  id                 String      @id @default(cuid())
  propertyId         String
  property           Property    @relation(fields: [propertyId], references: [id])
  agentId            String
  agent              Agent       @relation(fields: [agentId], references: [id])
  buyerId            String?
  buyer              User?       @relation("buyerDeals", fields: [buyerId], references: [id])
  sellerId           String?
  seller             User?       @relation("sellerDeals", fields: [sellerId], references: [id])
  salePriceRs        Int
  sellerAmountRs     Int
  commissionRs       Int
  platformFeePercent Float       @default(1.0)
  platformFeeRs      Int
  status             DealStatus  @default(PENDING)
  stripePaymentId    String?
  createdAt          DateTime    @default(now())
  completedAt        DateTime?

  @@map("deals")
}

enum DealStatus {
  PENDING
  APPROVED
  PAID
  COMPLETED
}

// ============================================
// PAYMENTS
// ============================================
model Payment {
  id              String      @id @default(cuid())
  agentId         String
  agent           Agent       @relation(fields: [agentId], references: [id])
  propertyId      String
  property        Property    @relation(fields: [propertyId], references: [id])
  amount          Int
  amountRs        Int
  type            PaymentType @default(PREMIUM)
  stripePaymentId String?
  status          PaymentStatus @default(PENDING)
  createdAt       DateTime    @default(now())

  @@map("payments")
}

enum PaymentType {
  PREMIUM
  FEATURED
  ESCROW
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ============================================
// SEARCH ALERTS
// ============================================
model SearchAlert {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  filters    Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("search_alerts")
}

// ============================================
// BLOG POSTS
// ============================================
model Blog {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  content    String
  image      String?
  authorId   String?
  author     User?    @relation(fields: [authorId], references: [id])
  status     BlogStatus @default(DRAFT)
  views      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("blogs")
}

enum BlogStatus {
  DRAFT
  PUBLISHED
}

// ============================================
// AREA GUIDES
// ============================================
model AreaGuide {
  id          String   @id @default(cuid())
  city        String   @unique
  slug        String   @unique
  title       String
  description String?
  content     String
  image       String?
  metaTitle   String?
  metaDesc    String?
  status      BlogStatus @default(DRAFT)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("area_guides")
}
