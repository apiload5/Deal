// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  agent
  user
  owner
}

enum PropertyStatus {
  pending
  approved
  rejected
  sold
}

enum DealStatus {
  pending
  approved
  paid
  completed
}

enum PaymentType {
  premium
  featured
  escrow
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String?
  image            String?
  role             Role      @default(user)
  stripeCustomerId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  agent           Agent?
  properties      Property[]
  reviews         Review[]
  wishlists       Wishlist[]
  searchAlerts    SearchAlert[]
  payments        Payment[]
  deals           Deal[]      @relation("BuyerDeals")
  sellerDeals     Deal[]      @relation("SellerDeals")
}

model Agent {
  id                String    @id @default(cuid())
  userId            String    @unique
  phone             String?
  company           String?
  officeAddress     String?
  officePhone       String?
  verified          Boolean   @default(false)
  stripeAccountId   String?
  rating            Float     @default(0)
  totalReviews      Int       @default(0)
  totalDealsCompleted Int    @default(0)
  slug              String    @unique
  bio               String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User      @relation(fields: [userId], references: [id])
  properties        Property[]
  reviews           Review[]
  deals             Deal[]
}

model Property {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  description     String
  price           Int
  priceFormatted  String
  city            String
  area            String
  propertyType    String
  beds            Int
  baths           Int
  areaSqft        Int
  furnished       Boolean       @default(false)
  floor           Int?
  builtYear       Int?
  images          String[]
  videoUrl        String?
  videoPlatform   String?
  latitude        Float?
  longitude       Float?
  isPremium       Boolean       @default(false)
  premiumExpiresAt DateTime?
  isFeatured      Boolean       @default(false)
  status          PropertyStatus @default(pending)
  views           Int           @default(0)
  whatsappClicks  Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  agentId         String?
  ownerId         String?
  agent           Agent?        @relation(fields: [agentId], references: [id])
  owner           User?         @relation(fields: [ownerId], references: [id])
  
  reviews         Review[]
  wishlists       Wishlist[]
  payments        Payment[]
  deals           Deal[]
}

model Review {
  id          String    @id @default(cuid())
  rating      Int
  comment     String?
  createdAt   DateTime  @default(now())

  propertyId  String?
  agentId     String?
  userId      String
  property    Property? @relation(fields: [propertyId], references: [id])
  agent       Agent?    @relation(fields: [agentId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
}

model Wishlist {
  id          String    @id @default(cuid())
  userId      String
  propertyId  String
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id])
  property    Property  @relation(fields: [propertyId], references: [id])

  @@unique([userId, propertyId])
}

model SearchAlert {
  id          String    @id @default(cuid())
  userId      String
  filters     Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id])
}

model Payment {
  id              String      @id @default(cuid())
  agentId         String
  propertyId      String?
  amount          Int
  amountRs        String
  type            PaymentType
  stripePaymentId String?
  status          String      @default("pending")
  createdAt       DateTime    @default(now())

  agent           User        @relation(fields: [agentId], references: [id])
  property        Property?   @relation(fields: [propertyId], references: [id])
}

model Deal {
  id                String      @id @default(cuid())
  propertyId        String
  agentId           String
  buyerId           String
  sellerId          String
  salePriceRs       Int
  sellerAmountRs    Int
  commissionRs      Int
  platformFeePercent Float      @default(1.0)
  platformFeeRs     Int
  status            DealStatus  @default(pending)
  createdAt         DateTime    @default(now())
  completedAt       DateTime?

  property          Property    @relation(fields: [propertyId], references: [id])
  agent             Agent       @relation(fields: [agentId], references: [id])
  buyer             User        @relation(fields: [buyerId], references: [id], name: "BuyerDeals")
  seller            User        @relation(fields: [sellerId], references: [id], name: "SellerDeals")
}

model Blog {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String
  image       String?
  authorId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author      User      @relation(fields: [authorId], references: [id])
}

model AreaGuide {
  id          String    @id @default(cuid())
  city        String
  area        String
  title       String
  content     String
  image       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([city, area])
}

model Setting {
  id                String    @id @default(cuid())
  adsenseClientId   String?
  seoTitle          String?
  seoDescription    String?
  platformFeePercent Float    @default(1.0)
  siteName          String    @default("Deal.pk")
  siteDescription   String    @default("Pakistan's #1 Real Estate Portal")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}
