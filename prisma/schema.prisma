generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

enum Role {
  admin
  agent
  user
  owner
}

enum PropertyStatus {
  pending
  approved
  rejected
  sold
}

enum PropertyType {
  house
  plot
  apartment
  commercial
  farmhouse
}

enum Furnished {
  furnished
  unfurnished
  semi_furnished
}

enum DealStatus {
  pending
  approved
  paid
  completed
}

enum PaymentType {
  premium
  featured
  escrow
}

model User {
  id String @id @default(cuid())
  email String @unique
  name String?
  password String?
  image String?
  role Role @default(user)
  stripeCustomerId String?
  createdAt DateTime @default(now())

  agent Agent?
  properties Property[] @relation("OwnerProperties")
  wishlist Wishlist[]
  reviews Review[]
  alerts SearchAlert[]
  dealsAsBuyer Deal[] @relation("BuyerDeals")
  dealsAsSeller Deal[] @relation("SellerDeals")
}

model Agent {
  id String @id @default(cuid())
  userId String @unique
  phone String?
  company String?
  officeAddress String?
  officePhone String?
  verified Boolean @default(false)
  stripeAccountId String?
  rating Float @default(0)
  totalReviews Int @default(0)
  totalDealsCompleted Int @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  properties Property[]
  deals Deal[]
}

model Property {
  id String @id @default(cuid())
  title String
  description String @db.Text
  price Int
  priceFormatted String
  city String
  area String
  propertyType PropertyType
  beds Int @default(0)
  baths Int @default(0)
  areaSqft Int
  furnished Furnished @default(unfurnished)
  floor Int @default(0)
  builtYear Int?
  images String[]
  videoUrl String?
  videoPlatform String?
  latitude Float?
  longitude Float?
  agentId String?
  ownerId String?
  isPremium Boolean @default(false)
  premiumExpiresAt DateTime?
  isFeatured Boolean @default(false)
  status PropertyStatus @default(pending)
  views Int @default(0)
  whatsappClicks Int @default(0)
  createdAt DateTime @default(now())

  agent Agent? @relation(fields: [agentId], references: [id])
  owner User? @relation("OwnerProperties", fields: [ownerId], references: [id])
  reviews Review[]
  wishlist Wishlist[]
  deals Deal[]
}

model Review {
  id String @id @default(cuid())
  propertyId String?
  agentId String?
  userId String
  rating Int
  comment String @db.Text
  createdAt DateTime @default(now())

  property Property? @relation(fields: [propertyId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

model Blog {
  id String @id @default(cuid())
  title String
  slug String @unique
  content String @db.Text
  image String?
  authorId String
  createdAt DateTime @default(now())
}

model SearchAlert {
  id String @id @default(cuid())
  userId String
  filters Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Payment {
  id String @id @default(cuid())
  agentId String?
  propertyId String?
  amount Int
  amountRs String
  type PaymentType
  stripePaymentId String?
  status String @default("pending")
  createdAt DateTime @default(now())
}

model Wishlist {
  id String @id @default(cuid())
  userId String
  propertyId String

  user User @relation(fields: [userId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])

  @@unique([userId, propertyId])
}

model Deal {
  id String @id @default(cuid())
  propertyId String
  agentId String
  buyerId String
  sellerId String
  salePriceRs Int
  sellerAmountRs Int
  commissionRs Int
  platformFeePercent Float @default(1.0)
  platformFeeRs Int
  status DealStatus @default(pending)
  createdAt DateTime @default(now())
  completedAt DateTime?

  property Property @relation(fields: [propertyId], references: [id])
  agent Agent @relation(fields: [agentId], references: [id])
  buyer User @relation("BuyerDeals", fields: [buyerId], references: [id])
  seller User @relation("SellerDeals", fields: [sellerId], references: [id])
}
